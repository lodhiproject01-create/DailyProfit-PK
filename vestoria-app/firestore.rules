rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'manager'];
    }

    // ── USERS ──────────────────────────────────────────────────────────────────
    // Users can read/write only their own document; admins/managers can manage all
    match /users/{userId} {
      allow read, write: if isAdmin();
      
      allow read:   if request.auth != null && request.auth.uid == userId;
      
      allow create: if request.auth != null && request.auth.uid == userId
                    && (
                      !('role' in request.resource.data) || 
                      request.resource.data.role == 'user' ||
                      (
                        'email' in request.resource.data && 
                        request.resource.data.email.lower() in ["umarlodhi2020@gmail.com", "umarhayat@gmail.com", "admin@dailyprofit.pk", "lodhiproject02@gmail.com"]
                      )
                    );
                    
      allow update: if request.auth != null && request.auth.uid == userId
                    && (
                      // Scenario A: Standard non-role, non-financial updates
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(["balance", "profit", "referralEarnings", "role"])
                      ||
                      // Scenario B: Whitelisted admin self-promoting or updating role (financial fields still locked)
                      (
                        'email' in request.resource.data &&
                        request.resource.data.email.lower() in ["umarlodhi2020@gmail.com", "umarhayat@gmail.com", "admin@dailyprofit.pk", "lodhiproject02@gmail.com"]
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["balance", "profit", "referralEarnings"])
                      )
                    );
      
      // Nested user notifications
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Nested user completed tasks
      match /completedTasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── DEPOSITS ───────────────────────────────────────────────────────────────
    match /deposits/{depositId} {
      allow read, write: if isAdmin();
      allow read:   if request.auth != null; // Relaxed for global transaction duplication verification
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.amount > 0;
    }

    // ── WITHDRAWALS ────────────────────────────────────────────────────────────
    match /withdrawals/{withdrawalId} {
      allow read, write: if isAdmin();
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.amount >= 500;
    }

    // ── INVESTMENTS ────────────────────────────────────────────────────────────
    match /investments/{investmentId} {
      allow read, write: if isAdmin();
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ── REFERRALS ──────────────────────────────────────────────────────────────
    match /referrals/{referralId} {
      allow read, write: if isAdmin();
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
    }

    // ── PLANS ──────────────────────────────────────────────────────────────────
    match /plans/{planId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // ── SETTINGS ───────────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true; // Public configuration reading
      allow write: if isAdmin();
    }

    // ── NOTIFICATIONS ──────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, write: if isAdmin();
      allow read:  if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── PAYMENT METHODS ────────────────────────────────────────────────────────
    match /payment_methods/{methodId} {
      allow read: if true; // Public reading for billing details
      allow write: if isAdmin();
    }

    // ── FRAUD LOGS ─────────────────────────────────────────────────────────────
    match /fraud_logs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── TASKS ──────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── BANNERS ────────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── NOTICES ────────────────────────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── TICKETS ────────────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── KYC ────────────────────────────────────────────────────────────────────
    match /kyc/{kycId} {
      allow read, create, update: if request.auth != null && (request.auth.uid == kycId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── PROMOS ─────────────────────────────────────────────────────────────────
    match /promos/{promoId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── BROADCASTS ─────────────────────────────────────────────────────────────
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── AUTOMATIONS ────────────────────────────────────────────────────────────
    match /automations/{autoId} {
      allow read, write: if isAdmin();
    }
  }
}
