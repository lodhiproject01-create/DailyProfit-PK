rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ──────────────────────────────────────────────────────────────────
    // Users can read/write only their own document
    match /users/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      
      allow create: if request.auth != null && request.auth.uid == userId
                    && (
                      !('role' in request.resource.data) || 
                      request.resource.data.role == 'user' ||
                      (
                        'email' in request.resource.data && 
                        request.resource.data.email.lower() in ["umarlodhi2020@gmail.com", "umarhayat@gmail.com", "admin@dailyprofit.pk"]
                      )
                    );
                    
      allow update: if request.auth != null && request.auth.uid == userId
                    && (
                      // Scenario A: Standard non-role, non-financial updates
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(["balance", "profit", "referralEarnings", "role"])
                      ||
                      // Scenario B: Whitelisted admin self-promoting or updating role (financial fields still locked)
                      (
                        'email' in request.resource.data &&
                        request.resource.data.email.lower() in ["umarlodhi2020@gmail.com", "umarhayat@gmail.com", "admin@dailyprofit.pk"]
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["balance", "profit", "referralEarnings"])
                     );
      
      // Nested user notifications
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── DEPOSITS ───────────────────────────────────────────────────────────────
    match /deposits/{depositId} {
      allow read:   if request.auth != null; // Relaxed for global transaction duplication verification
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.amount > 0;
      allow update: if false; // only admin (server) can update
    }

    // ── WITHDRAWALS ────────────────────────────────────────────────────────────
    match /withdrawals/{withdrawalId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.amount >= 500;
      allow update: if false;
    }

    // ── INVESTMENTS ────────────────────────────────────────────────────────────
    match /investments/{investmentId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── REFERRALS ──────────────────────────────────────────────────────────────
    match /referrals/{referralId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── PLANS ──────────────────────────────────────────────────────────────────
    match /plans/{planId} {
      allow read: if true; // Public
      allow write: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'manager'];
    }

    // ── SETTINGS ───────────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true; // Public configuration reading (for maintenance check & app download link)
      allow write: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'manager'];
    }

    // ── NOTIFICATIONS ──────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:  if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── PAYMENT METHODS ────────────────────────────────────────────────────────
    match /payment_methods/{methodId} {
      allow read: if true; // Public reading for billing details
      allow write: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'manager'];
    }

    // ── FRAUD LOGS ─────────────────────────────────────────────────────────────
    match /fraud_logs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'manager'];
    }
  }
}
